# ── Server ────────────────────────────────────────────────────────────────────
MCP_HOST=0.0.0.0
MCP_PORT=8400

# ── I14Y API ──────────────────────────────────────────────────────────────────
# "prod"  → https://api.i14y.admin.ch/api/public/v1   (default)
# "test"  → https://api-a.i14y.admin.ch/api/public/v1
I14Y_API_ENV=prod

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Sentry (optional) ─────────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_SAMPLE_RATE=0.1
